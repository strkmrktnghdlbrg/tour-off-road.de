# tour-off-road.de  WP -> Astro 301-Redirects (Apache / cPanel)
# Stand: 2026-06-09

# ---------------------------------------------------------------------------
# 1. HTTPS + www → non-www canonical
# ---------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTP → HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # www → non-www
  RewriteCond %{HTTP_HOST} ^www\.tour-off-road\.de [NC]
  RewriteRule ^ https://tour-off-road.de%{REQUEST_URI} [R=301,L]

# ---------------------------------------------------------------------------
# 2. WP → Astro 301-Redirects
#
# WICHTIG: Vier Legacy-URLs sind bewusst NICHT umgeleitet (bezahlte
# Gastbeitraege mit kommerziellen dofollow-Backlinks). Diese muessen
# 1:1 unter ihrer alten URL erhalten bleiben. Siehe MIGRATION.md.
# ---------------------------------------------------------------------------

  # --- Kategorie- / Themen-Seiten -------------------------------------------
  RewriteRule ^thema/ausruestung/?$        /ausruestung/    [R=301,L]
  RewriteRule ^thema/versicherungen/?$     /versicherungen/ [R=301,L]
  RewriteRule ^thema/besondere-routen/?$   /routen/         [R=301,L]
  RewriteRule ^thema/trekking/?$           /routen/         [R=301,L]
  RewriteRule ^thema/abenteuer/?$          /magazin/        [R=301,L]
  RewriteRule ^thema/urlaub/?$             /reiseziele/     [R=301,L]
  RewriteRule ^thema/blog/?$               /magazin/        [R=301,L]

  # --- Statische Seiten -----------------------------------------------------
  RewriteRule ^uber-uns/?$                 /ueber-uns/      [R=301,L]
  # /impressum/ und /datenschutz/ bleiben unveraendert (kein Redirect)

  # --- Einzel-Artikel (on-topic / unbedenklich) -----------------------------
  RewriteRule ^suedafrikas-outdoor-abenteuer-kulturelle-schaetze/?$        /magazin/suedafrika-outdoor-abenteuer/        [R=301,L]
  RewriteRule ^volvo-trucks-ruestet-fl-4x4-fuer-extreme-offroad-einsaetze-auf/?$   /magazin/volvo-fl-4x4-extreme-offroad/        [R=301,L]
  RewriteRule ^was-du-ueber-offroad-trekking-wissen-musst/?$               /magazin/offroad-trekking-grundlagen/         [R=301,L]
  RewriteRule ^offroad-trekking-mit-autos/?$                               /magazin/offroad-trekking-mit-autos/          [R=301,L]
  RewriteRule ^wie-waehle-ich-das-richtige-auto-fuer-mich-aus/?$           /magazin/richtiges-offroad-fahrzeug-waehlen/  [R=301,L]

  # --- Versicherungs-Artikel → Versicherungs-Cluster -----------------------
  RewriteRule ^schuelerreisen-versicherung/?$    /versicherungen/   [R=301,L]
  RewriteRule ^gruppenreisen-versicherung/?$     /versicherungen/   [R=301,L]
  RewriteRule ^langzeitreise-versicherung/?$     /versicherungen/   [R=301,L]
  RewriteRule ^reiseunfall-versicherung/?$       /versicherungen/   [R=301,L]
  RewriteRule ^reisehaftpflicht-versicherung/?$  /versicherungen/   [R=301,L]
  RewriteRule ^reisegepaeck-versicherung/?$      /versicherungen/   [R=301,L]
  RewriteRule ^reisekrankenversicherung/?$       /versicherungen/   [R=301,L]

  # Geloeschter Off-Topic-Gastbeitrag ohne Backlink (2026-06-03)
  RewriteRule ^smartphone-urlaub-reparieren-lassen/?$  /   [R=301,L]

</IfModule>

# ---------------------------------------------------------------------------
# 3. Gzip-Komprimierung
# ---------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE text/javascript application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml application/xhtml+xml
  AddOutputFilterByType DEFLATE font/woff font/woff2
</IfModule>

# ---------------------------------------------------------------------------
# 4. Caching-Header
# ---------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # Astro-Assets haben Content-Hash im Dateinamen → 1 Jahr cachen
  <FilesMatch "/_astro/.*\.(css|js|woff2?|jpg|jpeg|png|webp|avif|svg|ico)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Bilder ohne Hash → 1 Woche
  <FilesMatch "\.(jpg|jpeg|png|webp|avif|svg|gif|ico)$">
    ExpiresDefault "access plus 1 week"
  </FilesMatch>

  # HTML → kein Cache (immer frisch)
  <FilesMatch "\.html$">
    ExpiresDefault "access plus 0 seconds"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# ---------------------------------------------------------------------------
# 5. Sicherheits-Header
# ---------------------------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
