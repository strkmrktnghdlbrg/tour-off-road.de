    font-weight: 700;
  }
  .prose a {
    color: var(--blaze);
    font-weight: 600;
    text-decoration: underline;
  }
  .prose ul {
    margin: 0 0 16px 22px;
    list-style: disc;
  }
  .prose li {
    margin-bottom: 6px;
  }
  .draft-note {
    background: var(--blaze-soft);
