---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Announce from '../../components/Announce.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import MagCard from '../../components/MagCard.astro';

const posts = (await getCollection('magazin')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

// Demo-Kacheln aus dem Mockup (kommen via Content-Agent als echte Eintraege nach).
const demoPosts = [
  { href: '/magazin/volvo-fl-4x4-extreme-offroad/', hero: 'https://images.unsplash.com/photo-1558981403-c5f9899a28bc?w=700&q=70', category: 'Fahrzeuge', title: 'Volvo FL 4×4 für extreme Offroad-Einsätze', excerpt: 'Was der Truck-Umbau für Expeditionen taugt.' },
  { href: '/magazin/reifendruck-im-gelaende-faustregeln/', hero: 'https://images.unsplash.com/photo-1517524008697-84bbe3c3fd98?w=700&q=70', category: 'Ratgeber', title: 'Reifendruck im Gelände: die Faustregeln', excerpt: 'Sand, Schlamm, Fels - wann du Luft ablässt und wie viel.' },
];
---

<Base
  title="Magazin - tour-off-road.de"
  description="Trip-Reports, Fahrzeug-News und Wissen aus der Offroad- und Overland-Community."
  path="/magazin/"
>
  <Announce />
  <Header active="magazin" />

  <Breadcrumb items={[{ label: 'Start', href: '/' }, { label: 'Magazin' }]} />

  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Magazin</p>
      <h1>Geschichten von der Strecke.</h1>
      <p>Trip-Reports, Fahrzeug-News und Wissen aus der Community.</p>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="wrap">
      <div class="mag-grid">
        {
          posts.map((p) => (
            <MagCard
              href={`/magazin/${p.data.slug}/`}
              hero={p.data.hero}
              category={p.data.category}
              title={p.data.title}
              excerpt={p.data.excerpt}
            />
          ))
        }
        {demoPosts.map((p) => <MagCard {...p} />)}
      </div>
    </div>
  </section>

  <Footer />
</Base>
