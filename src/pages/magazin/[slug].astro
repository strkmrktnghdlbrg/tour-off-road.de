---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import Announce from '../../components/Announce.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import MagCard from '../../components/MagCard.astro';
import { articleSchema, breadcrumbSchema } from '../../seo';

export const getStaticPaths = (async () => {
  const posts = await getCollection('magazin');
  return posts.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const dateStr = d.date.toLocaleDateString('de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Weiterlesen: gleicher Cluster zuerst, dann andere Artikel.
const allPosts = await getCollection('magazin');
const others = allPosts.filter((p) => p.data.slug !== d.slug);
const sameCluster = others.filter((p) => p.data.cluster === d.cluster);
const otherClusters = others.filter((p) => p.data.cluster !== d.cluster);
const more = [...sameCluster, ...otherClusters].slice(0, 3).map((p) => ({
  href: `/magazin/${p.data.slug}/`,
  hero: p.data.hero,
  category: p.data.category,
  title: p.data.title,
}));

const path = `/magazin/${d.slug}/`;
const jsonLd = [
  articleSchema({
    title: d.title,
    description: d.excerpt,
    image: d.hero,
    url: path,
    author: d.author,
    datePublished: d.date,
  }),
  breadcrumbSchema([
    { label: 'Start', href: '/' },
    { label: 'Magazin', href: '/magazin/' },
    { label: d.title },
  ]),
];
---

<Base title={`${d.title} - Magazin - tour-off-road.de`} description={d.excerpt} image={d.hero} path={path} jsonLd={jsonLd}>
  <Announce />
  <Header active="magazin" />

  <Breadcrumb
    items={[
      { label: 'Start', href: '/' },
      { label: 'Magazin', href: '/magazin/' },
      { label: d.category },
    ]}
  />

  <article>
    <section class="page-hero" style="padding-bottom:16px">
      <div class="wrap" style="max-width:760px;margin:0 auto">
        <span class="eyebrow" style="color:var(--blaze)">{d.category} · {d.cluster}</span>
        <h1 style="margin-top:10px">{d.title}</h1>
        <div class="byline">
          <div class="av"></div>
          <div>Von <b>{d.author}</b> · {dateStr} · {d.readMinutes} Min. Lesezeit</div>
        </div>
      </div>
      <div class="wrap">
        <div class="g" style={`height:440px;border-radius:var(--radius);background-image:url('${d.hero}');background-size:cover;background-position:center`}></div>
      </div>
    </section>

    <section class="section" style="padding-top:40px">
      <div class="wrap">
        <div class="prose" style="margin:0 auto">
          <Content />
        </div>
      </div>
    </section>

    <section class="section tight">
      <div class="wrap">
        <div
          class="author-bio"
          style="max-width:760px;margin:0 auto;background:var(--parchment);border:1px solid var(--stone);border-radius:var(--radius);padding:28px;display:flex;gap:18px;align-items:flex-start"
        >
          <div class="av" style="flex:none;width:64px;height:64px;border-radius:50%;background:var(--olive)"></div>
          <div>
            <p class="eyebrow" style="color:var(--graphite);margin:0 0 4px">Autor</p>
            <h3 style="font-size:18px;font-weight:700;margin:0 0 6px">{d.author}</h3>
            <p class="muted" style="font-size:14px;line-height:1.55;margin:0">
              Fährt seit über zehn Jahren Offroad-Touren in Europa und Nordafrika. Schreibt über
              das, was wir selbst auf der Strecke testen - von der Atlas-Pass-Querung bis zum
              Recovery-Set für den Wochenend-Trip.
              <a href="/ueber-uns/" style="color:var(--blaze);font-weight:600">Mehr über uns</a>
            </p>
          </div>
        </div>
      </div>
    </section>
  </article>

  <section class="section tight">
    <div class="wrap">
      <div class="card-blaze" style="text-align:center">
        <h3 style="max-width:20ch;margin:0 auto 10px">Planst du selbst eine Fernreise?</h3>
        <p style="max-width:48ch;margin:0 auto 20px">
          Vergleich der Auslandskrankenversicherungen mit Rücktransport - speziell für lange
          Overland-Touren.
        </p>
        <a href="/versicherungen/" class="btn btn-ghost">Zum Versicherungs-Vergleich</a>
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="wrap">
      <div class="section-head">
        <div>
          <p class="eyebrow">Weiterlesen</p>
          <h2>Mehr aus dem Magazin</h2>
        </div>
      </div>
      <div class="mag-grid">
        {more.map((m) => <MagCard {...m} />)}
      </div>
    </div>
  </section>

  <Footer />
</Base>
