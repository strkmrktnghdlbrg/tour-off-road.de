---
import Base from '../layouts/Base.astro';
import Announce from '../components/Announce.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

// Alle Collections zur Build-Zeit in ein flaches Such-Array serialisieren.
const [routen, reiseziele, ausruestung, magazin] = await Promise.all([
  getCollection('routen'),
  getCollection('reiseziele'),
  getCollection('ausruestung'),
  getCollection('magazin'),
]);

type SearchItem = {
  title: string;
  excerpt: string;
  href: string;
  image: string;
  kind: string;
};

const index: SearchItem[] = [
  ...routen.map((e) => ({
    title: e.data.title,
    excerpt: e.data.excerpt ?? '',
    href: `/routen/${e.data.slug}/`,
    image: e.data.hero,
    kind: 'Route',
  })),
  ...reiseziele.map((e) => ({
    title: e.data.title,
    excerpt: e.data.excerpt ?? '',
    href: `/reiseziele/${e.data.slug}/`,
    image: e.data.hero,
    kind: 'Reiseziel',
  })),
  ...ausruestung.map((e) => ({
    title: e.data.title,
    excerpt: e.data.excerpt ?? '',
    href: `/ausruestung/${e.data.category}/`,
    image: e.data.image,
    kind: 'Ausrüstung',
  })),
  ...magazin.map((e) => ({
    title: e.data.title,
    excerpt: e.data.excerpt ?? '',
    href: `/magazin/${e.data.slug}/`,
    image: e.data.hero,
    kind: 'Magazin',
  })),
];

// Statische Hub- und Info-Seiten, damit auch sie auffindbar sind.
const staticPages: SearchItem[] = [
  {
    title: 'Routen-Atlas',
    excerpt: 'Alle Offroad- und Overland-Routen im Überblick, nach Region und Schwierigkeit.',
    href: '/routen/',
    image: 'https://images.unsplash.com/photo-1489493887464-892be6d1daae?w=900&q=70',
    kind: 'Seite',
  },
  {
    title: 'Reiseziele',
    excerpt: 'Länder und Regionen für deine nächste Allrad-Tour, mit Anreise und bester Reisezeit.',
    href: '/reiseziele/',
    image: 'https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?w=900&q=70',
    kind: 'Seite',
  },
  {
    title: 'Ausrüstung',
    excerpt: 'Bergung, Camping, Navigation, Campküche und Reifen für unterwegs.',
    href: '/ausruestung/',
    image: 'https://images.unsplash.com/photo-1533473359331-0135ef1b58bf?w=900&q=70',
    kind: 'Seite',
  },
  {
    title: 'Magazin',
    excerpt: 'Reiseberichte, Ratgeber und Tipps rund um Offroad und Overlanding.',
    href: '/magazin/',
    image: 'https://images.unsplash.com/photo-1523987355523-c7b5b0dd90a7?w=900&q=70',
    kind: 'Seite',
  },
  {
    title: 'Reiseplanung',
    excerpt: 'Schritt für Schritt zur eigenen Offroad-Tour: Vorbereitung, Route und Checklisten.',
    href: '/reiseplanung/',
    image: 'https://images.unsplash.com/photo-1500534623283-312aade485b7?w=900&q=70',
    kind: 'Seite',
  },
  {
    title: 'Versicherungen',
    excerpt: 'Reise- und Fahrzeugversicherungen für lange Touren im Vergleich.',
    href: '/versicherungen/',
    image: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=900&q=70',
    kind: 'Seite',
  },
  {
    title: 'Über uns',
    excerpt: 'Wer hinter tour-off-road.de steckt und wofür wir stehen.',
    href: '/ueber-uns/',
    image: 'https://images.unsplash.com/photo-1532974297617-c0f05fe48bff?w=900&q=70',
    kind: 'Seite',
  },
  {
    title: 'Kontakt',
    excerpt: 'Fragen, Feedback oder Kooperationsanfragen? So erreichst du uns.',
    href: '/kontakt/',
    image: 'https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?w=900&q=70',
    kind: 'Seite',
  },
];

const fullIndex: SearchItem[] = [...index, ...staticPages];
---

<Base
  title="Suche - tour-off-road.de"
  description="Durchsuche alle Routen, Reiseziele, Ausrüstung und Magazin-Artikel auf tour-off-road.de."
  path="/suche/"
>
  <Announce />
  <Header active={null} />

  <Breadcrumb items={[{ label: 'Start', href: '/' }, { label: 'Suche' }]} />

  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Suche</p>
      <h1>Finde deine nächste Tour.</h1>
      <p>
        Durchsuche Routen, Reiseziele, Ausrüstung und Magazin in einem Feld. Tipp einfach
        los, die Ergebnisse erscheinen sofort.
      </p>

      <div class="searchbar" style="max-width:680px;margin:32px auto 0">
        <div class="field" style="border-right:none;flex:1">
          <label class="lbl" for="q">Suchbegriff</label>
          <input
            id="q"
            type="search"
            class="val search-input"
            placeholder="z.B. Marokko, Dachzelt, Sand ..."
            autocomplete="off"
            autofocus
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section tight" style="padding-top:8px">
    <div class="wrap">
      <p id="search-status" class="muted" style="margin-bottom:24px;font-weight:600"></p>
      <div id="results" class="route-grid"></div>
    </div>
  </section>

  <Footer />
</Base>

<script define:vars={{ index: fullIndex }}>
  const input = document.getElementById('q');
  const results = document.getElementById('results');
  const status = document.getElementById('search-status');

  function escapeHtml(s) {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function render(items) {
    results.innerHTML = items
      .map(
        (it) => `
        <a href="${escapeHtml(it.href)}" class="route">
          <div class="img" style="background-image:url('${escapeHtml(it.image)}')">
            <div class="badges"><span class="badge">${escapeHtml(it.kind)}</span></div>
          </div>
          <div class="body">
            <h3>${escapeHtml(it.title)}</h3>
            <p class="muted" style="font-size:14px;margin-top:6px">${escapeHtml(it.excerpt)}</p>
          </div>
        </a>`
      )
      .join('');
  }

  function search(term) {
    const q = term.trim().toLowerCase();
    if (!q) {
      results.innerHTML = '';
      status.textContent = 'Tippe einen Begriff ein, um zu suchen.';
      return;
    }
    const tokens = q.split(/\s+/);
    const hits = index.filter((it) => {
      const hay = (it.title + ' ' + it.excerpt + ' ' + it.kind).toLowerCase();
      return tokens.every((t) => hay.includes(t));
    });
    status.textContent =
      hits.length === 0
        ? `Keine Treffer für „${term}". Versuch einen anderen Begriff.`
        : `${hits.length} ${hits.length === 1 ? 'Treffer' : 'Treffer'} für „${term}".`;
    render(hits);
  }

  // Initialer Zustand + optionaler ?q=-Parameter
  const params = new URLSearchParams(window.location.search);
  const initial = params.get('q') || '';
  if (initial) {
    input.value = initial;
    search(initial);
  } else {
    status.textContent = 'Tippe einen Begriff ein, um zu suchen.';
  }

  input.addEventListener('input', (e) => search(e.target.value));
</script>

<style>
  .search-input {
    width: 100%;
    border: none;
    background: transparent;
    font-family: var(--font);
    font-size: 16px;
    font-weight: 600;
    color: var(--basalt);
    padding: 0;
  }
  .search-input:focus {
    outline: none;
  }
  .search-input::placeholder {
    color: var(--graphite);
    font-weight: 500;
  }
  #results:empty {
    min-height: 0;
  }
</style>
