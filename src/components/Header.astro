---
// Sticky-Navigation. active-Prop steuert den hervorgehobenen Menuepunkt.
type NavKey =
  | 'routen'
  | 'reiseziele'
  | 'fahrzeuge'
  | 'ausruestung'
  | 'ratgeber'
  | 'versicherungen'
  | 'magazin'
  | 'reiseplanung'
  | null;

interface Props {
  active?: NavKey;
}
const { active = null } = Astro.props;

const links: { key: NavKey; label: string; href: string }[] = [
  { key: 'routen', label: 'Routen', href: '/routen/' },
  { key: 'reiseplanung', label: 'Reiseplanung', href: '/reiseplanung/' },
  { key: 'reiseziele', label: 'Reiseziele', href: '/reiseziele/' },
  { key: 'fahrzeuge', label: 'Fahrzeuge', href: '#' },
  { key: 'ausruestung', label: 'Ausrüstung', href: '/ausruestung/' },
  { key: 'ratgeber', label: 'Ratgeber', href: '#' },
  { key: 'versicherungen', label: 'Versicherungen', href: '/versicherungen/' },
  { key: 'magazin', label: 'Magazin', href: '/magazin/' },
];
---

<header class="nav">
  <div class="wrap nav-inner">
    <a href="/" class="logo"
      ><span class="mark"><span></span></span> tour<span style="color:var(--blaze)"
        >off</span
      >road</a
    >
    <nav class="nav-links">
      {
        links.map((l) => (
          <a href={l.href} class={active === l.key ? 'active' : undefined}>
            {l.label}
          </a>
        ))
      }
    </nav>
    <div class="nav-right">
      <a href="/ueber-uns/" class="btn btn-ghost">Über uns</a>
      <a href="/routen/" class="btn btn-primary">Route finden</a>
    </div>
    <button
      type="button"
      class="nav-burger"
      id="navBurger"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobileDrawer"
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav-backdrop" id="navBackdrop" hidden></div>

  <aside
    class="nav-drawer"
    id="mobileDrawer"
    aria-hidden="true"
    aria-label="Hauptnavigation"
  >
    <div class="nav-drawer-head">
      <span class="nav-drawer-title">Navigation</span>
      <button
        type="button"
        class="nav-drawer-close"
        id="navClose"
        aria-label="Menü schließen"
      >
        <span></span><span></span>
      </button>
    </div>
    <nav class="nav-drawer-links">
      {
        links.map((l) => (
          <a href={l.href} class={active === l.key ? 'active' : undefined}>
            {l.label}
          </a>
        ))
      }
    </nav>
    <div class="nav-drawer-cta">
      <a href="/ueber-uns/" class="btn btn-ghost">Über uns</a>
      <a href="/routen/" class="btn btn-primary">Route finden</a>
    </div>
  </aside>
</header>

<script is:inline>
  (function () {
    var burger = document.getElementById('navBurger');
    var drawer = document.getElementById('mobileDrawer');
    var backdrop = document.getElementById('navBackdrop');
    var closeBtn = document.getElementById('navClose');
    if (!burger || !drawer || !backdrop) return;

    function open() {
      document.body.classList.add('drawer-open');
      burger.setAttribute('aria-expanded', 'true');
      burger.setAttribute('aria-label', 'Menü schließen');
      drawer.setAttribute('aria-hidden', 'false');
      backdrop.hidden = false;
    }

    function close() {
      document.body.classList.remove('drawer-open');
      burger.setAttribute('aria-expanded', 'false');
      burger.setAttribute('aria-label', 'Menü öffnen');
      drawer.setAttribute('aria-hidden', 'true');
      backdrop.hidden = true;
    }

    function toggle() {
      if (document.body.classList.contains('drawer-open')) {
        close();
      } else {
        open();
      }
    }

    burger.addEventListener('click', toggle);
    if (closeBtn) closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && document.body.classList.contains('drawer-open')) {
        close();
      }
    });

    // Bei Klick auf einen Link das Menü schließen.
    drawer.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', close);
    });
  })();
</script>
